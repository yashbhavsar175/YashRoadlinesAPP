# Environment Configuration Template
# Copy this to .env for local development

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Firebase Configuration (if using Firebase directly)
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id

# Optional: Firebase Service Account (for server-side operations)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-credentials.json

# SendGrid (for email)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDER_EMAIL=noreply@yourdomain.com

# FCM (Firebase Cloud Messaging)
FCM_SERVER_KEY=your-fcm-server-key

# Other API Keys
# Add any other API keys or secrets here
