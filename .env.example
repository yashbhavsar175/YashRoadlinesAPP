# Firebase Configuration
# DO NOT commit actual credentials - use environment variables
# Copy this file to .env and fill in your actual values

# Firebase Service Account (JSON string or path to JSON file)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-credentials.json

# Or use individual environment variables
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_CLIENT_EMAIL=your-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Private-Key-Here\n-----END PRIVATE KEY-----"
